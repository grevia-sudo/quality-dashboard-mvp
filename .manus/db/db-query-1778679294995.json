  "query": "SELECT psd.`userId`, DATE_FORMAT(psd.`businessDate`, '%Y-%m-%d') AS businessDate, psd.`stationEventId`, COUNT(*) AS detailCount, GROUP_CONCAT(psd.`id` ORDER BY psd.`id`) AS detailIds\nFROM `productivity_score_details` psd\nINNER JOIN `users` u ON u.`id` = psd.`userId`\nWHERE COALESCE(u.`name`, u.`username`) = '宥凱' AND psd.`businessDate` = CURRENT_DATE()\nGROUP BY psd.`userId`, psd.`businessDate`, psd.`stationEventId`\nHAVING COUNT(*) > 1\nORDER BY detailCount DESC, psd.`stationEventId` ASC;\n\nSELECT p.`batchNo`, p.`id` AS productId, p.`sheetRowNumber`, p.`lastSheetSyncedAt`, p.`stationCode`, p.`productStatus`\nFROM `products` p\nWHERE p.`batchNo` IN ('00500025209','00500025225','00500025228','00500025229','00500025239','00500025240','00500025241','00500025247','00500025252','00500025253','00500025256','00500025264','00500025266','00500025269','00500025271')\nORDER BY p.`batchNo` ASC;",
