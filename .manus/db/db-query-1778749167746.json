{
  "query": "SELECT u.id AS user_id, u.name, u.username\nFROM users u\nWHERE u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%';\n\nSELECT u.name AS engineer_name,\n       se.businessDate,\n       se.id AS station_event_id,\n       se.productId,\n       se.countForProductivity,\n       psd.id AS detail_id,\n       psd.targetConfigId,\n       psd.earnedPoints,\n       p.batchNo,\n       p.importedCategoryName,\n       p.importedBrandName,\n       p.categoryId AS product_category_id\nFROM station_events se\nJOIN users u ON u.id = se.operatorUserId\nJOIN products p ON p.id = se.productId\nLEFT JOIN productivity_score_details psd ON psd.stationEventId = se.id\nWHERE se.stationCode = 'E'\n  AND se.stationEventType = 'complete'\n  AND (u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%')\n  AND se.businessDate >= DATE_FORMAT(CURDATE(), '%Y-%m-01')\nORDER BY se.businessDate DESC, se.id DESC\nLIMIT 100;\n\nSELECT u.name AS engineer_name,\n       edp.businessDate,\n       edp.totalPoints,\n       edp.kpiAchievementRate,\n       edp.finalKpiScore\nFROM engineer_daily_productivity edp\nJOIN users u ON u.id = edp.userId\nWHERE (u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%')\n  AND edp.businessDate >= DATE_FORMAT(CURDATE(), '%Y-%m-01')\nORDER BY edp.businessDate DESC;",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway05.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 27YhjuzT1vAAGri.3f5f101aaba8 --database F4LQWhZd9GGdmJuBm98r2c --execute SELECT u.id AS user_id, u.name, u.username\nFROM users u\nWHERE u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%';\n\nSELECT u.name AS engineer_name,\n       se.businessDate,\n       se.id AS station_event_id,\n       se.productId,\n       se.countForProductivity,\n       psd.id AS detail_id,\n       psd.targetConfigId,\n       psd.earnedPoints,\n       p.batchNo,\n       p.importedCategoryName,\n       p.importedBrandName,\n       p.categoryId AS product_category_id\nFROM station_events se\nJOIN users u ON u.id = se.operatorUserId\nJOIN products p ON p.id = se.productId\nLEFT JOIN productivity_score_details psd ON psd.stationEventId = se.id\nWHERE se.stationCode = 'E'\n  AND se.stationEventType = 'complete'\n  AND (u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%')\n  AND se.businessDate >= DATE_FORMAT(CURDATE(), '%Y-%m-01')\nORDER BY se.businessDate DESC, se.id DESC\nLIMIT 100;\n\nSELECT u.name AS engineer_name,\n       edp.businessDate,\n       edp.totalPoints,\n       edp.kpiAchievementRate,\n       edp.finalKpiScore\nFROM engineer_daily_productivity edp\nJOIN users u ON u.id = edp.userId\nWHERE (u.name LIKE '%巧克力%' OR u.username LIKE '%巧克力%')\n  AND edp.businessDate >= DATE_FORMAT(CURDATE(), '%Y-%m-01')\nORDER BY edp.businessDate DESC;",
