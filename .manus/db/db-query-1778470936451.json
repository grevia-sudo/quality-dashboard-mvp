{
  "query": "SELECT 'serialNumber' AS identity_type,\n       serialNumber AS identity_value,\n       COUNT(*) AS duplicate_count,\n       GROUP_CONCAT(id ORDER BY id DESC) AS product_ids,\n       GROUP_CONCAT(DISTINCT poNumber ORDER BY poNumber DESC) AS po_numbers\nFROM products\nWHERE archivedAt IS NULL\n  AND serialNumber IS NOT NULL\n  AND TRIM(serialNumber) <> ''\nGROUP BY serialNumber\nHAVING COUNT(*) > 1\nORDER BY duplicate_count DESC, MAX(id) DESC\nLIMIT 20;\n\nSELECT 'imei' AS identity_type,\n       imei AS identity_value,\n       COUNT(*) AS duplicate_count,\n       GROUP_CONCAT(id ORDER BY id DESC) AS product_ids,\n       GROUP_CONCAT(DISTINCT poNumber ORDER BY poNumber DESC) AS po_numbers\nFROM products\nWHERE archivedAt IS NULL\n  AND imei IS NOT NULL\n  AND TRIM(imei) <> ''\nGROUP BY imei\nHAVING COUNT(*) > 1\nORDER BY duplicate_count DESC, MAX(id) DESC\nLIMIT 20;",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway05.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 27YhjuzT1vAAGri.3f5f101aaba8 --database F4LQWhZd9GGdmJuBm98r2c --execute SELECT 'serialNumber' AS identity_type,\n       serialNumber AS identity_value,\n       COUNT(*) AS duplicate_count,\n       GROUP_CONCAT(id ORDER BY id DESC) AS product_ids,\n       GROUP_CONCAT(DISTINCT poNumber ORDER BY poNumber DESC) AS po_numbers\nFROM products\nWHERE archivedAt IS NULL\n  AND serialNumber IS NOT NULL\n  AND TRIM(serialNumber) <> ''\nGROUP BY serialNumber\nHAVING COUNT(*) > 1\nORDER BY duplicate_count DESC, MAX(id) DESC\nLIMIT 20;\n\nSELECT 'imei' AS identity_type,\n       imei AS identity_value,\n       COUNT(*) AS duplicate_count,\n       GROUP_CONCAT(id ORDER BY id DESC) AS product_ids,\n       GROUP_CONCAT(DISTINCT poNumber ORDER BY poNumber DESC) AS po_numbers\nFROM products\nWHERE archivedAt IS NULL\n  AND imei IS NOT NULL\n  AND TRIM(imei) <> ''\nGROUP BY imei\nHAVING COUNT(*) > 1\nORDER BY duplicate_count DESC, MAX(id) DESC\nLIMIT 20;",
