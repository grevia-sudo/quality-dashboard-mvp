  "query": "SELECT u.id AS userId, u.name, u.username, se.stationEventType, COUNT(*) AS eventCount\nFROM station_events se\nLEFT JOIN users u ON u.id = se.operatorUserId\nWHERE se.stationCode = 'D'\n  AND DATE_FORMAT(se.businessDate, '%Y-%m') = DATE_FORMAT(CURDATE(), '%Y-%m')\nGROUP BY u.id, u.name, u.username, se.stationEventType\nORDER BY eventCount DESC, u.id ASC, se.stationEventType ASC;\n\nSELECT se.id AS stationEventId, se.businessDate, se.stationEventType, se.countForProductivity, se.productId, p.batchNo\nFROM station_events se\nLEFT JOIN products p ON p.id = se.productId\nWHERE se.stationCode = 'D'\n  AND se.operatorUserId = 750189\n  AND DATE_FORMAT(se.businessDate, '%Y-%m') = DATE_FORMAT(CURDATE(), '%Y-%m')\nORDER BY se.businessDate DESC, se.id DESC;",
