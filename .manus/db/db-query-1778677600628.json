{
  "query": "SELECT COUNT(*) AS detailRows, COUNT(DISTINCT productId) AS distinctProducts, COUNT(DISTINCT stationEventId) AS distinctEvents, ROUND(SUM(earnedPoints), 6) AS totalEarnedPoints FROM productivity_score_details WHERE userId = 750192;\n\nSELECT p.batchNo, COUNT(*) AS scoreRows, ROUND(SUM(psd.earnedPoints), 6) AS batchPoints, MIN(psd.businessDate) AS firstDate, MAX(psd.businessDate) AS lastDate FROM productivity_score_details psd JOIN products p ON p.id = psd.productId WHERE psd.userId = 750192 GROUP BY p.batchNo HAVING COUNT(*) > 1 ORDER BY scoreRows DESC, p.batchNo LIMIT 30;\n\nSELECT psd.businessDate, psd.stationCode, p.batchNo, p.serialNumber, p.imei, ROUND(psd.earnedPoints, 6) AS earnedPoints FROM productivity_score_details psd JOIN products p ON p.id = psd.productId WHERE psd.userId = 750192 ORDER BY psd.businessDate DESC, p.batchNo LIMIT 140;",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway05.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 27YhjuzT1vAAGri.3f5f101aaba8 --database F4LQWhZd9GGdmJuBm98r2c --execute SELECT COUNT(*) AS detailRows, COUNT(DISTINCT productId) AS distinctProducts, COUNT(DISTINCT stationEventId) AS distinctEvents, ROUND(SUM(earnedPoints), 6) AS totalEarnedPoints FROM productivity_score_details WHERE userId = 750192;\n\nSELECT p.batchNo, COUNT(*) AS scoreRows, ROUND(SUM(psd.earnedPoints), 6) AS batchPoints, MIN(psd.businessDate) AS firstDate, MAX(psd.businessDate) AS lastDate FROM productivity_score_details psd JOIN products p ON p.id = psd.productId WHERE psd.userId = 750192 GROUP BY p.batchNo HAVING COUNT(*) > 1 ORDER BY scoreRows DESC, p.batchNo LIMIT 30;\n\nSELECT psd.businessDate, psd.stationCode, p.batchNo, p.serialNumber, p.imei, ROUND(psd.earnedPoints, 6) AS earnedPoints FROM productivity_score_details psd JOIN products p ON p.id = psd.productId WHERE psd.userId = 750192 ORDER BY psd.businessDate DESC, p.batchNo LIMIT 140;",
