  "query": "SELECT COUNT(*) AS a1CompleteEvents, COUNT(DISTINCT productId) AS a1DistinctProducts FROM station_events WHERE operatorUserId = 750192 AND businessDate = '2026-05-13' AND stationCode = 'A1' AND stationEventType = 'complete';\n\nSELECT COUNT(*) AS duplicatedEventCount FROM (SELECT stationEventId FROM productivity_score_details WHERE userId = 750192 GROUP BY stationEventId HAVING COUNT(*) > 1) duplicated;\n\nSELECT psd.stationEventId, p.batchNo, COUNT(*) AS scoreRows, ROUND(SUM(psd.earnedPoints), 6) AS totalEarnedPoints, MIN(psd.createdAt) AS firstInsertedAt, MAX(psd.createdAt) AS lastInsertedAt FROM productivity_score_details psd JOIN products p ON p.id = psd.productId WHERE psd.userId = 750192 GROUP BY psd.stationEventId, p.batchNo HAVING COUNT(*) > 1 ORDER BY scoreRows DESC, psd.stationEventId LIMIT 30;",
