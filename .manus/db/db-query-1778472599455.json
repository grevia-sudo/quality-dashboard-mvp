{
  "query": "WITH active_products AS (\n  SELECT id, productCode, poNumber, vendorName, batchNo, serialNumber, imei,\n         CASE WHEN poNumber IS NULL OR poNumber = '' THEN 'without_po' ELSE 'with_po' END AS sourceType\n  FROM products\n  WHERE archivedAt IS NULL\n), duplicate_groups AS (\n  SELECT 'serialNumber' AS duplicateType, serialNumber AS duplicateValue\n  FROM active_products\n  WHERE serialNumber IS NOT NULL AND serialNumber <> ''\n  GROUP BY serialNumber\n  HAVING COUNT(*) > 1\n  UNION ALL\n  SELECT 'imei' AS duplicateType, imei AS duplicateValue\n  FROM active_products\n  WHERE imei IS NOT NULL AND imei <> ''\n  GROUP BY imei\n  HAVING COUNT(*) > 1\n), mixed_groups AS (\n  SELECT g.duplicateType, g.duplicateValue\n  FROM duplicate_groups g\n  JOIN active_products p\n    ON (g.duplicateType = 'serialNumber' AND p.serialNumber = g.duplicateValue)\n    OR (g.duplicateType = 'imei' AND p.imei = g.duplicateValue)\n  GROUP BY g.duplicateType, g.duplicateValue\n  HAVING SUM(CASE WHEN p.sourceType = 'with_po' THEN 1 ELSE 0 END) > 0\n     AND SUM(CASE WHEN p.sourceType = 'without_po' THEN 1 ELSE 0 END) > 0\n)\nSELECT m.duplicateType, m.duplicateValue, p.id, p.productCode, p.poNumber, p.vendorName, p.batchNo, p.serialNumber, p.imei, p.sourceType\nFROM mixed_groups m\nJOIN active_products p\n  ON (m.duplicateType = 'serialNumber' AND p.serialNumber = m.duplicateValue)\n  OR (m.duplicateType = 'imei' AND p.imei = m.duplicateValue)\nORDER BY m.duplicateType, m.duplicateValue, p.sourceType, p.id;",
